{
  "name": "hypha",
  "displayName": "Hypha — SysML v2 Agent",
  "version": "0.0.1",
  "description": "Hypha is the AI agent of the Mycelium ecosystem: a connecting filament between engineers and the SysML v2 specification. Provides skills and subagents for KerML/SysML v2 metamodel lookup, normative spec citation, and SysML v2 textual-notation validation.",
  "author": {
    "name": "Starion Group S.A.",
    "url": "https://github.com/mycelium-cmbse"
  },
  "homepage": "https://github.com/mycelium-cmbse/mycelium-hypha",
  "repository": "https://github.com/mycelium-cmbse/mycelium-hypha",
  "license": "Apache-2.0",
  "keywords": [
    "sysml",
    "sysml-v2",
    "kerml",
    "mbse",
    "omg",
    "metamodel",
    "systems-engineering"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/check-spec-pdfs.py\""
          }
        ]
      }
    ]
  }
}
