<?xml version="1.0" encoding="utf-8"?>
<!--
  Repo-local NuGet configuration. Clears any inherited (machine/user) package
  sources so restore is reproducible and isolated, then enables nuget.org.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <!-- Override any inherited disabling of nuget.org from machine/user config. -->
  <disabledPackageSources>
    <clear />
  </disabledPackageSources>
</configuration>
