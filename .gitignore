# ---------------------------------------------------------------------------
# Raw source documents (see sources/README.md).
# The XMI / UML metamodel files ARE committed (sources/xmi/) so the generator
# tests are reproducible. OMG PDF specifications are copyrighted and MUST NOT
# be committed.
# ---------------------------------------------------------------------------
sources/specs/*
sources/textual/*
!sources/**/.gitkeep

# ---------------------------------------------------------------------------
# Generated spec knowledge base (verbatim OMG spec text). Regenerated locally
# from the PDFs by tools/spec-extract; NOT redistributed (OMG terms). The
# directory placeholders are kept so the layout is tracked.
# ---------------------------------------------------------------------------
knowledge/spec/kerml/*
knowledge/spec/sysml2/*
!knowledge/spec/**/.gitkeep

# ---------------------------------------------------------------------------
# .NET (tools/metamodel-gen)
# ---------------------------------------------------------------------------
bin/
obj/
*.user
*.suo
.vs/

# ---------------------------------------------------------------------------
# Python (tools/spec-extract)
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# ---------------------------------------------------------------------------
# Editors / OS
# ---------------------------------------------------------------------------
.idea/
.DS_Store
Thumbs.db
