{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mycelium-cmbse/mycelium-hypha/blob/main/knowledge/sysml2/metamodel.schema.json",
  "title": "Hypha metamodel graph",
  "description": "Structured graph form of the combined KerML + SysML v2 metamodel, generated by tools/metamodel-gen alongside the markdown. Multiplicity upper bound -1 denotes unbounded (*).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "metamodel", "modelVersionUri", "sourceXmiSha256", "counts", "packages", "classes", "enumerations", "primitiveTypes"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "metamodel": { "type": "string" },
    "modelVersionUri": { "type": "string" },
    "sourceXmiSha256": { "type": "string" },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classes", "enumerations", "primitiveTypes", "packages"],
      "properties": {
        "classes": { "type": "integer" },
        "enumerations": { "type": "integer" },
        "primitiveTypes": { "type": "integer" },
        "packages": { "type": "integer" }
      }
    },
    "packages": { "type": "array", "items": { "$ref": "#/$defs/package" } },
    "classes": { "type": "array", "items": { "$ref": "#/$defs/class" } },
    "enumerations": { "type": "array", "items": { "$ref": "#/$defs/enumeration" } },
    "primitiveTypes": { "type": "array", "items": { "$ref": "#/$defs/primitiveType" } }
  },
  "$defs": {
    "names": { "type": "array", "items": { "type": "string" } },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "qualifiedName", "parent", "classes"],
      "properties": {
        "name": { "type": "string" },
        "qualifiedName": { "type": "string" },
        "parent": { "type": ["string", "null"] },
        "classes": { "$ref": "#/$defs/names" }
      }
    },
    "class": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "xmiId", "package", "qualifiedName", "isAbstract", "visibility", "documentation", "summary", "extends", "allAncestors", "directSubclasses", "allDescendants", "ownedAttributes", "inheritedAttributes", "ownedOperations", "constraints"],
      "properties": {
        "name": { "type": "string" },
        "xmiId": { "type": "string" },
        "package": { "type": "string" },
        "qualifiedName": { "type": "string" },
        "isAbstract": { "type": "boolean" },
        "visibility": { "type": "string" },
        "documentation": { "type": "string" },
        "summary": { "type": "string" },
        "extends": { "$ref": "#/$defs/names" },
        "allAncestors": { "$ref": "#/$defs/names" },
        "directSubclasses": { "$ref": "#/$defs/names" },
        "allDescendants": { "$ref": "#/$defs/names" },
        "ownedAttributes": { "type": "array", "items": { "$ref": "#/$defs/attribute" } },
        "inheritedAttributes": { "type": "array", "items": { "$ref": "#/$defs/inheritedAttribute" } },
        "ownedOperations": { "type": "array", "items": { "$ref": "#/$defs/operation" } },
        "constraints": { "type": "array", "items": { "$ref": "#/$defs/constraint" } }
      }
    },
    "attribute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "typeIsElement", "visibility", "lower", "upper", "isDerived", "isComposite", "isOrdered", "redefines", "subsets", "documentation"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": ["string", "null"] },
        "typeIsElement": { "type": "boolean" },
        "visibility": { "type": "string" },
        "lower": { "type": "integer", "minimum": 0 },
        "upper": { "type": "integer", "minimum": -1 },
        "isDerived": { "type": "boolean" },
        "isComposite": { "type": "boolean" },
        "isOrdered": { "type": "boolean" },
        "redefines": { "$ref": "#/$defs/names" },
        "subsets": { "$ref": "#/$defs/names" },
        "documentation": { "type": "string" }
      }
    },
    "inheritedAttribute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "typeIsElement", "visibility", "lower", "upper", "isDerived", "isComposite", "isOrdered", "redefines", "subsets", "documentation", "inheritedFrom"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": ["string", "null"] },
        "typeIsElement": { "type": "boolean" },
        "visibility": { "type": "string" },
        "lower": { "type": "integer", "minimum": 0 },
        "upper": { "type": "integer", "minimum": -1 },
        "isDerived": { "type": "boolean" },
        "isComposite": { "type": "boolean" },
        "isOrdered": { "type": "boolean" },
        "redefines": { "$ref": "#/$defs/names" },
        "subsets": { "$ref": "#/$defs/names" },
        "documentation": { "type": "string" },
        "inheritedFrom": { "type": "string" }
      }
    },
    "operation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "returnType", "returnLower", "returnUpper", "isQuery", "parameters"],
      "properties": {
        "name": { "type": "string" },
        "returnType": { "type": ["string", "null"] },
        "returnLower": { "type": "integer", "minimum": 0 },
        "returnUpper": { "type": "integer", "minimum": -1 },
        "isQuery": { "type": "boolean" },
        "parameters": { "type": "array", "items": { "$ref": "#/$defs/operationParameter" } }
      }
    },
    "operationParameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "direction", "lower", "upper"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": ["string", "null"] },
        "direction": { "type": "string" },
        "lower": { "type": "integer", "minimum": 0 },
        "upper": { "type": "integer", "minimum": -1 }
      }
    },
    "constraint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "documentation", "ocl"],
      "properties": {
        "name": { "type": "string" },
        "documentation": { "type": "string" },
        "ocl": { "type": "string" }
      }
    },
    "enumeration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "xmiId", "package", "qualifiedName", "visibility", "documentation", "summary", "literals"],
      "properties": {
        "name": { "type": "string" },
        "xmiId": { "type": "string" },
        "package": { "type": "string" },
        "qualifiedName": { "type": "string" },
        "visibility": { "type": "string" },
        "documentation": { "type": "string" },
        "summary": { "type": "string" },
        "literals": { "type": "array", "items": { "$ref": "#/$defs/enumerationLiteral" } }
      }
    },
    "enumerationLiteral": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "documentation"],
      "properties": {
        "name": { "type": "string" },
        "documentation": { "type": "string" }
      }
    },
    "primitiveType": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "xmiId", "package", "qualifiedName", "visibility", "documentation", "summary"],
      "properties": {
        "name": { "type": "string" },
        "xmiId": { "type": "string" },
        "package": { "type": "string" },
        "qualifiedName": { "type": "string" },
        "visibility": { "type": "string" },
        "documentation": { "type": "string" },
        "summary": { "type": "string" }
      }
    }
  }
}
