{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/mycelium-cmbse/mycelium-hypha/blob/development/knowledge/metamodel/index.schema.json",
  "title": "Hypha metamodel index",
  "description": "Flat name -> record lookup over the combined KerML + SysML v2 metamodel, generated by tools/metamodel-gen. Keyed by element simple name (classes, enumerations and primitive types).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "metamodel", "modelVersionUri", "entries"],
  "properties": {
    "schemaVersion": { "type": "string" },
    "metamodel": { "type": "string" },
    "modelVersionUri": { "type": "string" },
    "entries": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/entry" }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "package", "qualifiedName", "isAbstract", "summary", "extends", "file"],
      "properties": {
        "kind": { "enum": ["class", "enumeration", "primitiveType"] },
        "package": { "type": "string" },
        "qualifiedName": { "type": "string" },
        "isAbstract": { "type": "boolean" },
        "summary": { "type": "string" },
        "extends": { "type": "array", "items": { "type": "string" } },
        "file": { "type": "string" }
      }
    }
  }
}
